{
  "name": "@horizon/config-exporter",
  "version": "0.2.0",
  "description": "CLI tool to export Azure App Configuration to a Horizon config.js file",
  "license": "UNLICENSED",
  "bin": {
    "export-horizon-config": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
